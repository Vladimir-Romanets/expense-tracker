{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=24.18.0",
    "pnpm": ">=8.15.9"
  },
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate:docker": "docker compose exec api pnpm drizzle-kit migrate",
    "db:check": "drizzle-kit check",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "1.0.0-rc.4",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.3.0",
    "joi": "^18.2.3",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "1.0.0-rc.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.2"
  }
}
