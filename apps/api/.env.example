# API settings
API_HOST="127.0.0.1"      # Host address the API should run on (e.g. 127.0.0.1 or 0.0.0.0)
API_PORT=3001            # Port number for the API server (e.g. 3001)

# PostgreSQL Connection details
DB_USERNAME="postgres"   # Database username (e.g. postgres)
DB_PASSWORD="password"   # Database password
DB_HOST="localhost"      # Hostname of the database for local dev scripts (Docker always uses 'pgdb')
DB_PORT=5432             # Port number of the database (default 5432)
DB_NAME="expense_tracker"# Name of the database to connect to
DB_DIALECT="postgres"    # Database dialect/type (postgres)

# (Optional) Full database connection URL override
# DATABASE_URL="postgresql://postgres:password@localhost:5432/expense_tracker"

# JWT Authentication
JWT_SECRET="your_jwt_secret_key_here"  # Secret key used for signing and verifying JWT tokens
JWT_EXPIRES_IN="1h"                    # Token expiry duration (e.g. 1h, 7d, 30m). Default: 1h

